<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ispw.view.gui.fxml.DisdettaFXMLController"
      styleClass="root" stylesheets="/css/app.css"
      spacing="10" alignment="TOP_CENTER">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>
    
    <Label text="❌ Disdetta (Richiesta)" styleClass="title"/>
    
    <Label fx:id="lblError" styleClass="error"/>
    
    <Label fx:id="lblSuccess" styleClass="muted"/>
    
    <ListView fx:id="listPrenotazioni" prefHeight="200"/>
    
    <TextField fx:id="txtIdPrenotazione" promptText="Id prenotazione"/>
    
    <Label fx:id="lblAnteprima" styleClass="muted"/>
    
    <Button text="Ricarica prenotazioni" onAction="#onRicarica" styleClass="secondary"/>
    
    <Button text="Anteprima" onAction="#onAnteprima" styleClass="primary"/>
    
    <Button text="Invia richiesta disdetta" onAction="#onInviaRichiesta" styleClass="primary"/>
    
    <Button text="Home" onAction="#onHome" styleClass="secondary"/>
</VBox>