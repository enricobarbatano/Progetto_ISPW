<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ispw.view.gui.fxml.PrenotazioneFXMLController"
            fitToWidth="true"
            stylesheets="/css/app.css"
            styleClass="scroll-pane">

    <content>
        <VBox alignment="TOP_CENTER" spacing="30" styleClass="root">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox spacing="10" alignment="CENTER">
                <Label text="Prenota un Campo" styleClass="title"/>
                <Label fx:id="lblError" text="" styleClass="error" wrapText="true"/>
                <Label fx:id="lblSuccess" text="" styleClass="success-label" wrapText="true"/>
            </VBox>

            <!-- STEP 1: RICERCA -->
            <VBox fx:id="boxSearch" spacing="20" maxWidth="700" styleClass="card">
                <HBox alignment="CENTER_LEFT">
                    <Label text="1. Scegli Campo e Orario" styleClass="subtitle"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="🔄 Aggiorna Campi" onAction="#onListaCampi" styleClass="secondary" style="-fx-padding: 5 15;"/>
                </HBox>
                
                <ListView fx:id="listCampi" prefHeight="150" styleClass="list-view"/>
                <TextField fx:id="txtIdCampo" visible="false" managed="false"/> <!-- ID nascosto ma funzionale -->

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33"/>
                        <ColumnConstraints percentWidth="33"/>
                        <ColumnConstraints percentWidth="33"/>
                    </columnConstraints>

                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="Data" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Orario" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="comboOra" maxWidth="Infinity">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="08:00"/><String fx:value="09:00"/><String fx:value="10:00"/>
                                    <String fx:value="11:00"/><String fx:value="12:00"/><String fx:value="15:00"/>
                                    <String fx:value="16:00"/><String fx:value="17:00"/><String fx:value="18:00"/>
                                    <String fx:value="19:00"/><String fx:value="20:00"/><String fx:value="21:00"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="2">
                        <Label text="Durata (ore)" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtDurata" promptText="Es: 1"/>
                    </VBox>
                </GridPane>

                <Button text="Cerca Disponibilità" onAction="#onCerca" maxWidth="Infinity" styleClass="primary"/>
            </VBox>

            <!-- STEP 2: SLOT -->
            <VBox fx:id="boxSlots" spacing="20" maxWidth="700" styleClass="card" visible="false" managed="false">
                <Label text="2. Seleziona lo Slot esatto" styleClass="subtitle"/>
                <ListView fx:id="listSlots" prefHeight="200" styleClass="list-view"/>
                <HBox spacing="15">
                    <Button text="Conferma Slot" onAction="#onSelezionaSlot" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="primary"/>
                    <Button text="Annulla" onAction="#onReset" styleClass="secondary"/>
                </HBox>
            </VBox>

            <!-- STEP 3: PAGAMENTO -->
            <VBox fx:id="boxPagamento" spacing="20" maxWidth="700" styleClass="card" visible="false" managed="false">
                <Label text="3. Riepilogo e Pagamento" styleClass="subtitle"/>
                
                <VBox spacing="15" styleClass="info-box">
                    <Label fx:id="lblRiepilogo" text="..." wrapText="true" style="-fx-font-size: 15px;"/>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Totale:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblImporto" text="0.00 EUR" style="-fx-font-size: 20px; -fx-text-fill: -fx-primary-color; -fx-font-weight: 800;"/>
                    </HBox>
                </VBox>

                <GridPane hgap="20" vgap="15">
                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="Metodo di Pagamento" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtMetodo" promptText="Esempio: CARTA_CREDITO"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Codice Fiscale / ID" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtCredenziale" promptText="Per ricevuta fiscale"/>
                    </VBox>
                </GridPane>

                <HBox spacing="15">
                    <Button text="Paga e Conferma" onAction="#onPaga" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="primary"/>
                    <Button text="Indietro" onAction="#onIndietroSlots" styleClass="secondary"/>
                </HBox>
            </VBox>

            <!-- STEP 4: ESITO -->
            <VBox fx:id="boxEsito" spacing="25" maxWidth="600" alignment="CENTER" styleClass="card" visible="false" managed="false">
                <Label text="Operazione Completata" styleClass="subtitle" style="-fx-text-fill: -fx-success-color;"/>
                <Label fx:id="lblEsitoPagamento" text="..." style="-fx-font-size: 16px;" textAlignment="CENTER" wrapText="true"/>
                <Button text="Torna alla Dashboard" onAction="#onHome" styleClass="primary" prefWidth="250"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Dashboard" onAction="#onHome" styleClass="secondary"/>
                <Button text="Annulla Tutto" onAction="#onReset" styleClass="danger" style="-fx-background-color: transparent;"/>
            </HBox>
        </VBox>
    </content>
</ScrollPane>