<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ispw.view.gui.fxml.RichiesteDisdettaFXMLController"
      styleClass="root" stylesheets="/css/app.css"
      spacing="10" alignment="TOP_CENTER">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>
    
    <Label text="📋 Richieste disdetta (Gestore)" styleClass="title"/>
    
    <Label fx:id="lblError" styleClass="error"/>
    
    <Label fx:id="lblSuccess" styleClass="muted"/>
    
    <ListView fx:id="listRichieste" prefHeight="200"/>
    
    <TextField fx:id="txtIdRichiesta" promptText="Id richiesta"/>
    
    <TextArea fx:id="txtNotaGestore" promptText="Nota gestore (opzionale)" prefRowCount="3"/>
    
    <Button text="Ricarica" onAction="#onRicarica" styleClass="secondary"/>
    
    <Button text="Approva" onAction="#onApprova" styleClass="primary"/>
    
    <Button text="Rifiuta" onAction="#onRifiuta" styleClass="danger"/>
    
    <Button text="Home" onAction="#onHome" styleClass="secondary"/>
</VBox>
