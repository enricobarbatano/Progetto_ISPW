<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ispw.view.gui.fxml.RichiesteDisdettaFXMLController"
            fitToWidth="true"
            stylesheets="/css/app.css"
            styleClass="scroll-pane">

    <content>
        <VBox alignment="TOP_CENTER" spacing="25" styleClass="root">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox spacing="20" maxWidth="850" alignment="TOP_CENTER">
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Richieste di Disdetta" styleClass="title"/>
                    <Label text="Approva o rifiuta le richieste inviate dagli utenti" style="-fx-text-fill: -fx-text-muted;"/>
                </VBox>
                
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblError" text="" styleClass="error" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblSuccess" text="" styleClass="success-label"/>
                    <Button text="🔄 Ricarica" onAction="#onRicarica" styleClass="secondary" style="-fx-padding: 5 15;"/>
                </HBox>

                <VBox styleClass="card">
                    <ListView fx:id="listRichieste" prefHeight="250" styleClass="list-view"/>
                </VBox>

                <VBox spacing="20" styleClass="card">
                    <Label text="Gestione Richiesta Selezionata" styleClass="subtitle"/>
                    
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="ID Richiesta:" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtIdRichiesta" prefWidth="100" disable="true" style="-fx-opacity: 0.8;"/>
                    </HBox>

                    <VBox spacing="8">
                        <Label text="Nota per l'utente (mostrata nella conferma):" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="txtNotaGestore" promptText="Inserisci qui il motivo della decisione..." prefHeight="100" wrapText="true"/>
                    </VBox>

                    <HBox spacing="20" alignment="CENTER">
                        <Button text="✅ Approva Disdetta" onAction="#onApprova" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="primary" style="-fx-background-color: -fx-success-color;"/>
                        <Button text="❌ Rifiuta Richiesta" onAction="#onRifiuta" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="danger"/>
                    </HBox>
                </VBox>

                <Button text="Home" onAction="#onHome" styleClass="secondary"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>