<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ispw.view.gui.fxml.LogFXMLController"
            fitToWidth="true"
            stylesheets="/css/app.css"
            styleClass="scroll-pane">

    <content>
        <VBox alignment="TOP_CENTER" spacing="25" styleClass="root">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox spacing="20" maxWidth="900" alignment="TOP_CENTER">
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Log di Sistema" styleClass="title"/>
                    <Label text="Registro cronologico delle attività e degli errori" style="-fx-text-fill: -fx-text-muted;"/>
                </VBox>

                <Label fx:id="lblError" text="" styleClass="error" wrapText="true"/>

                <VBox styleClass="card" VBox.vgrow="ALWAYS">
                    <ListView fx:id="listLogs" prefHeight="450" styleClass="list-view"/>
                </VBox>

                <HBox spacing="15" alignment="CENTER">
                    <Button text="Aggiorna Registro" onAction="#onRefresh" styleClass="primary"/>
                    <Button text="Torna alla Home" onAction="#onHome" styleClass="secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>